"Testing abs"

clear
check(abs(x) == x)
check(abs(-x) == x)
check(abs(1) == 1)
check(abs(-1) == 1)
check(abs(exp(1)) == exp(1))
check(abs(-exp(1)) == exp(1))
check(abs(sqrt(2)) == sqrt(2))
check(abs(-sqrt(2)) == sqrt(2))
check(abs(1/sqrt(2)) == 1/sqrt(2))
check(abs(-1/sqrt(2)) == 1/sqrt(2))
check(abs(1/x) == 1/x)
check(abs(-1/x) == 1/x)
check(abs(1+2i) == sqrt(5))
check(abs((1+2i,3+4i)) == sqrt(5+25))
check(abs((x,y)) == sqrt(x^2+y^2))
check(abs(r exp(i theta)) == r)

t = abs(2)
check(t = 2)
t = abs(2.0)
check(t = 2)
t = abs(-2)
check(t = 2)
t = abs(-2.0)
check(t = 2)
t = abs(3 + 4 i)
check(t = 5)
t = abs((2,3,4))
check(t = 29^(1/2))
